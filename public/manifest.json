{
    "manifest_version": 3,
    "name": "Study Lock",
    "version": "0.1.0",
    "description": "Study-only browsing and ChatGPT wrapper.",
    "action": {
        "default_popup": "src/popup.html"
    },
    "options_page": "src/options.html",
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "declarativeNetRequest",
        "alarms",
        "windows"
    ],
    "host_permissions": [
        "<all_urls>",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [ "assets/close-guard.js" ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://*.chatgpt.com/*"
            ],
            "js": [ "assets/chatgpt.js" ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [ "blocked.html", "blocked.js" ],
            "matches": [ "<all_urls>" ]
        }
    ]
}
